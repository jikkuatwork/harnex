#!/usr/bin/env ruby

require_relative "../lib/harnex"

begin
  exit(Harnex::Sender.new(ARGV).run)
rescue OptionParser::ParseError => e
  trace = ENV["HARNEX_TRACE"] == "1" || ENV["CXW_TRACE"] == "1"
  warn "harnex-send: #{e.message}"
  warn "Try: harnex-send --help" unless trace
  warn e.backtrace.join("\n") if trace
  exit 2
rescue StandardError => e
  trace = ENV["HARNEX_TRACE"] == "1" || ENV["CXW_TRACE"] == "1"
  warn "harnex-send: #{e.message}"
  warn e.backtrace.join("\n") if trace
  exit 1
end
